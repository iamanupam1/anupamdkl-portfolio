---
import Layout from './Layout.astro';
import Nav from '../components/Nav.astro';
import { getSiteInfo } from '../lib/content';

const site = await getSiteInfo();

interface Props {
  title: string;
  date: Date;
  tags: string[];
  summary?: string;
}

const { title, date, tags, summary } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(date);
---

<Layout title={`${title} — ${site.name}`} description={summary} ogType="article">
  <Nav solid />

  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": title,
    "datePublished": date.toISOString(),
    "description": summary || '',
    "author": {
      "@type": "Person",
      "name": site.name,
      "url": site.siteUrl
    }
  })} />

  <article class="blog-post" id="main-content">
    <header class="blog-post-header">
      <div class="blog-post-header-inner">
        <a href="/blog" class="blog-post-back">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M13 8H3m0 0l4-4m-4 4l4 4" />
          </svg>
          All posts
        </a>
        <h1 class="blog-post-title">{title}</h1>
        <div class="blog-post-title-bar"></div>
        <div class="blog-post-meta">
          <time class="blog-post-date" datetime={date.toISOString()}>{formattedDate}</time>
          <span class="blog-post-meta-sep">&middot;</span>
          <span class="blog-post-reading-time" id="reading-time"></span>
          <span class="blog-post-meta-sep" id="reading-time-sep" style="display:none;">&middot;</span>
          <div class="blog-post-tags">
            {tags.map((tag) => (
              <span class="blog-post-tag">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </header>

    <div class="blog-post-content">
      <div class="blog-post-body" id="blog-post-body">
        <slot />
      </div>

      <aside class="blog-post-sidebar">
        <div class="sidebar-sticky">
          <div class="sidebar-label">In this article</div>
          <nav class="sidebar-toc" id="sidebar-toc"></nav>
        </div>
      </aside>
    </div>

    <footer class="blog-post-footer">
      <div class="blog-post-footer-inner">
        <div class="blog-post-footer-divider"></div>
        <a href="/blog" class="blog-post-footer-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M13 8H3m0 0l4-4m-4 4l4 4" />
          </svg>
          Back to all posts
        </a>
      </div>
    </footer>
  </article>

  <button class="scroll-to-top" id="scroll-to-top" aria-label="Scroll to top">
    <svg width="18" height="18" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M8 14V2m0 0L4 6m4-4l4 4" />
    </svg>
  </button>
</Layout>

<script>
  // Scroll to top
  const btn = document.getElementById('scroll-to-top');
  if (btn) {
    window.addEventListener('scroll', () => {
      btn.classList.toggle('visible', window.scrollY > 400);
    });
    btn.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // Reading time
  const body = document.getElementById('blog-post-body');
  const readingTimeEl = document.getElementById('reading-time');
  const readingTimeSep = document.getElementById('reading-time-sep');
  if (body && readingTimeEl) {
    const text = body.textContent || '';
    const words = text.trim().split(/\s+/).length;
    const minutes = Math.max(1, Math.round(words / 230));
    readingTimeEl.textContent = `${minutes} min read`;
    if (readingTimeSep) readingTimeSep.style.display = '';
  }

  // Build TOC from H2s
  const tocNav = document.getElementById('sidebar-toc');
  if (body && tocNav) {
    const headings = body.querySelectorAll('h2');
    const tocLinks: HTMLAnchorElement[] = [];

    headings.forEach((h2, i) => {
      if (!h2.id) {
        h2.id = 'section-' + i;
      }

      const link = document.createElement('a');
      link.href = '#' + h2.id;
      link.className = 'toc-link';
      link.textContent = h2.textContent || '';
      link.addEventListener('click', (e) => {
        e.preventDefault();
        h2.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
      tocNav.appendChild(link);
      tocLinks.push(link);
    });

    if (tocLinks.length > 0) {
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          let activeIndex = 0;
          headings.forEach((h2, i) => {
            if (h2.getBoundingClientRect().top < 120) {
              activeIndex = i;
            }
          });
          tocLinks.forEach((link, i) => {
            link.classList.toggle('active', i === activeIndex);
          });
          ticking = false;
        });
      });
      tocLinks[0]?.classList.add('active');
    }
  }
</script>

<style>
  .blog-post {
    padding-top: 72px;
  }

  /* --- Header (centered) --- */
  .blog-post-header {
    padding: 72px 48px 48px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .blog-post-header-inner {
    max-width: 780px;
    margin: 0 auto;
  }

  .blog-post-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-dim);
    font-size: 13px;
    margin-bottom: 32px;
    transition: color 0.3s;
    font-weight: 300;
  }

  .blog-post-back:hover {
    color: var(--accent);
  }

  .blog-post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .blog-post-date,
  .blog-post-reading-time {
    font-family: var(--font-body);
    color: var(--text-dim);
    font-size: 13px;
    font-weight: 300;
  }

  .blog-post-meta-sep {
    color: var(--text-dim);
    font-size: 13px;
  }

  .blog-post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .blog-post-tag {
    font-family: var(--font-body);
    color: var(--accent);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 400;
    background: var(--accent-tint);
    padding: 3px 10px;
    border-radius: 4px;
  }

  .blog-post-title {
    font-family: var(--font-display);
    font-size: clamp(30px, 5vw, 48px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -0.5px;
  }

  .blog-post-title-bar {
    width: 48px;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  /*
   * Content area: grid with body + sidebar.
   * Body is centered via padding. Sidebar sits to the right.
   * Key: NO align-items: start — the sidebar cell must stretch
   * full height of the body so sticky has room to scroll.
   */
  .blog-post-content {
    display: grid;
    grid-template-columns: 780px 200px;
    max-width: calc(780px + 48px + 200px);
    margin: 0 auto;
    /* Shift grid left so the 780px body column is centered on page */
    transform: translateX(calc((200px + 48px) / 2));
  }

  /* --- Body (first grid column) --- */
  .blog-post-body {
    max-width: 780px;
    padding: 56px 48px 80px 0;
    color: var(--text-muted);
    font-size: 17px;
    line-height: 1.85;
    min-width: 0;
  }

  .blog-post-body :global(h2) {
    font-family: var(--font-display);
    color: var(--text-primary);
    font-size: 26px;
    font-weight: 600;
    margin: 64px 0 20px;
    letter-spacing: -0.3px;
    padding-top: 16px;
    border-top: 1px solid var(--border-subtle);
    scroll-margin-top: 100px;
  }

  .blog-post-body :global(h2:first-child) {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
  }

  .blog-post-body :global(h3) {
    font-family: var(--font-display);
    color: var(--text-primary);
    font-size: 20px;
    font-weight: 600;
    margin: 44px 0 14px;
  }

  .blog-post-body :global(p) {
    margin-bottom: 24px;
  }

  .blog-post-body :global(p + p) {
    margin-top: -4px;
  }

  .blog-post-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-decoration-color: var(--accent-underline);
    text-underline-offset: 3px;
    transition: text-decoration-color 0.2s;
  }

  .blog-post-body :global(a:hover) {
    text-decoration-color: var(--accent);
  }

  .blog-post-body :global(code) {
    background: var(--accent-tint);
    border: 1px solid var(--code-border);
    padding: 2px 7px;
    border-radius: 5px;
    font-size: 0.88em;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    color: var(--accent-light);
  }

  .blog-post-body :global(pre) {
    background: var(--accent-tint-subtle);
    border: 1px solid var(--accent-tint);
    border-radius: 12px;
    padding: 24px 28px;
    margin: 32px 0;
    overflow-x: auto;
  }

  .blog-post-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    font-size: 14px;
    line-height: 1.7;
    color: var(--text-muted);
  }

  .blog-post-body :global(ul),
  .blog-post-body :global(ol) {
    margin: 20px 0;
    padding-left: 20px;
  }

  .blog-post-body :global(li) {
    margin-bottom: 12px;
    padding-left: 4px;
  }

  .blog-post-body :global(li::marker) {
    color: var(--accent);
  }

  .blog-post-body :global(strong) {
    color: var(--text-primary);
    font-weight: 500;
  }

  .blog-post-body :global(em) {
    color: var(--text-primary);
    font-style: italic;
  }

  .blog-post-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 16px 24px;
    margin: 32px 0;
    background: var(--accent-tint-subtle);
    border-radius: 0 8px 8px 0;
    color: var(--text-muted);
    font-style: italic;
    font-size: 16px;
    line-height: 1.7;
  }

  .blog-post-body :global(blockquote p) {
    margin-bottom: 0;
  }

  .blog-post-body :global(hr) {
    border: none;
    height: 1px;
    background: var(--border-subtle);
    margin: 48px 0;
  }

  .blog-post-body :global(img) {
    max-width: 100%;
    border-radius: 12px;
    margin: 32px 0;
  }

  /* --- Sidebar (second grid column, stretches full height) --- */
  .blog-post-sidebar {
    padding-top: 56px;
    padding-left: 48px;
    border-left: 1px solid var(--border-subtle);
  }

  .sidebar-sticky {
    position: sticky;
    top: 96px;
  }

  .sidebar-label {
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 400;
    margin-bottom: 12px;
  }

  .sidebar-toc {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .sidebar-toc :global(.toc-link) {
    display: block;
    font-size: 13px;
    color: var(--text-dim);
    padding: 5px 12px;
    border-left: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s;
    line-height: 1.4;
  }

  .sidebar-toc :global(.toc-link:hover) {
    color: var(--text-primary);
  }

  .sidebar-toc :global(.toc-link.active) {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  /* --- Footer (centered) --- */
  .blog-post-footer {
    padding: 0 48px 80px;
  }

  .blog-post-footer-inner {
    max-width: 780px;
    margin: 0 auto;
  }

  .blog-post-footer-divider {
    height: 1px;
    background: var(--border-subtle);
    margin-bottom: 40px;
  }

  .blog-post-footer-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border: 1px solid var(--border-subtle);
    border-radius: 8px;
    color: var(--text-muted);
    font-size: 14px;
    transition: all 0.3s var(--ease-cinematic);
  }

  .blog-post-footer-link:hover {
    border-color: var(--accent);
    color: var(--text-primary);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  /* --- Scroll to top --- */
  .scroll-to-top {
    position: fixed;
    bottom: 32px;
    right: 32px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--accent-tint);
    border: 1px solid var(--accent-glow);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(10px);
    transition: all 0.3s var(--ease-cinematic);
    pointer-events: none;
    z-index: 50;
  }

  .scroll-to-top.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .scroll-to-top:hover {
    background: var(--accent-glow);
    border-color: var(--accent);
    box-shadow: 0 0 16px var(--accent-glow);
  }

  /* --- Responsive --- */
  @media (max-width: 1200px) {
    .blog-post-content {
      grid-template-columns: 1fr;
      max-width: 780px;
      transform: none;
    }

    .blog-post-sidebar {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .blog-post-header {
      padding: 56px 24px 36px;
    }

    .blog-post-content {
      padding: 0 24px;
    }

    .blog-post-body {
      padding: 36px 0 60px;
      font-size: 16px;
    }

    .blog-post-footer {
      padding: 0 24px 60px;
    }

    .blog-post-body :global(h2) {
      font-size: 22px;
      margin: 48px 0 16px;
    }

    .blog-post-body :global(h3) {
      font-size: 18px;
      margin: 32px 0 12px;
    }

    .blog-post-body :global(pre) {
      padding: 16px 20px;
      border-radius: 8px;
    }

    .blog-post-body :global(blockquote) {
      padding: 12px 16px;
      margin: 24px 0;
    }

    .scroll-to-top {
      bottom: 20px;
      right: 20px;
    }
  }
</style>
