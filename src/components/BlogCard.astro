---
interface Props {
  slug: string;
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  gradient: string;
}

const { slug, title, summary, date, tags, gradient } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(date);
---

<a href={`/blog/${slug}`} class="blog-card">
  <div class="blog-card-image" style={`background: ${gradient}`}>
    <span class="blog-card-image-label">{formattedDate}</span>
  </div>
  <div class="blog-card-body">
    <div class="blog-card-tags">
      {tags.map((tag) => (
        <span class="blog-card-tag">{tag}</span>
      ))}
    </div>
    <h3 class="blog-card-title">{title}</h3>
    <p class="blog-card-summary">{summary}</p>
  </div>
</a>

<style>
  .blog-card {
    display: block;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-subtle);
    border-radius: 16px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.4s var(--ease-cinematic);
    opacity: 0;
  }

  .blog-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(129, 140, 248, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .blog-card-image {
    height: 140px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 16px;
  }

  .blog-card-image-label {
    color: rgba(255, 255, 255, 0.5);
    font-size: 12px;
    letter-spacing: 1px;
    font-weight: 400;
  }

  .blog-card-body {
    padding: 24px;
  }

  .blog-card-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }

  .blog-card-tag {
    color: var(--accent-start);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .blog-card-title {
    font-size: 18px;
    font-weight: 500;
    margin-bottom: 8px;
    line-height: 1.3;
  }

  .blog-card-summary {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.6;
  }
</style>
