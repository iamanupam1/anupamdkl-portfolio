---
interface Props {
  slug: string;
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  gradient: string;
}

const { slug, title, summary, date, tags, gradient } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(date);
---

<a href={`/blog/${slug}`} class="blog-card">
  <div class="project-image" style={`background: linear-gradient(135deg, rgba(99,102,241,0.1), rgba(168,85,247,0.1))`}>
    <span>BLOG PREVIEW</span>
  </div>
  <span class="project-tag">{formattedDate}</span>
  <h3>{title}</h3>
  <p>{summary}</p>
</a>

<style>
  .blog-card {
    display: block;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 32px;
    transition: all 0.4s var(--ease-standard);
    cursor: pointer;
    opacity: 0;
  }

  .blog-card:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(99, 102, 241, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .project-image {
    height: 180px;
    border-radius: 8px;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4b5563;
    font-size: 12px;
    letter-spacing: 1px;
  }

  .project-tag {
    display: inline-block;
    color: var(--accent-light);
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .blog-card h3 {
    font-size: 20px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .blog-card p {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.6;
  }
</style>
