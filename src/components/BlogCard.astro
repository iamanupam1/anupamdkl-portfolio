---
interface Props {
  slug: string;
  title: string;
  summary: string;
  date: Date;
  tags: string[];
  gradient: string;
}

const { slug, title, summary, date, tags, gradient } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(date);
---

<a href={`/blog/${slug}`} class="blog-card">
  <div class="blog-card-meta">
    <time class="blog-card-date">{formattedDate}</time>
    <span class="blog-card-sep">&middot;</span>
    <div class="blog-card-tags">
      {tags.map((tag) => (
        <span class="blog-card-tag">{tag}</span>
      ))}
    </div>
  </div>
  <h3 class="blog-card-title">{title}</h3>
  <p class="blog-card-summary">{summary}</p>
  <span class="blog-card-read">Read article &rarr;</span>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    padding: 32px;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    opacity: 0;
  }

  .blog-card:hover {
    border-color: rgba(200, 245, 66, 0.2);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.25);
  }

  .blog-card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 14px;
    overflow: hidden;
    white-space: nowrap;
  }

  .blog-card-date {
    color: var(--text-dim);
    font-size: 12px;
    font-weight: 300;
  }

  .blog-card-sep {
    color: var(--text-dim);
    font-size: 12px;
  }

  .blog-card-tags {
    display: flex;
    gap: 6px;
  }

  .blog-card-tag {
    font-size: 9px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(200, 245, 66, 0.06);
    padding: 2px 8px;
    border-radius: 3px;
  }

  .blog-card-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 10px;
    line-height: 1.3;
    letter-spacing: -0.2px;
    transition: color 0.2s;
  }

  .blog-card:hover .blog-card-title {
    color: var(--accent);
  }

  .blog-card-summary {
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.65;
    flex: 1;
  }

  .blog-card-read {
    display: inline-block;
    margin-top: 20px;
    font-size: 13px;
    color: var(--text-dim);
    transition: color 0.2s;
  }

  .blog-card:hover .blog-card-read {
    color: var(--accent);
  }
</style>
