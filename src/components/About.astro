---
import { getSection } from '../lib/content';
const about = await getSection('about');
const { Content } = await about.render();
---

<div class="about-block">
  <span class="section-label">{about.data.label}</span>
  <h2 class="section-title">{about.data.title}</h2>
  <div class="about-grid">
    <div class="about-text">
      <Content />
    </div>
  </div>
</div>

<style>
  .about-block {
    margin-bottom: 96px;
  }

  .section-label {
    display: block;
    color: var(--accent);
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 16px;
    font-weight: 400;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 40px;
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 48px;
  }

  .about-grid {
    max-width: 680px;
  }

  .about-text {
    color: var(--text-muted);
    font-size: 16px;
    line-height: 1.8;
  }

  .about-text p {
    margin-bottom: 16px;
    opacity: 0;
  }

  @media (max-width: 768px) {
    .about-block {
      margin-bottom: 64px;
    }

    .section-title {
      font-size: 32px;
      margin-bottom: 32px;
    }

    .about-text {
      font-size: 15px;
    }
  }
</style>
