---
import { projects } from '../data/projects';
---

<div class="overlay-backdrop" id="overlay-backdrop"></div>
<div class="overlay" id="project-overlay" role="dialog" aria-modal="true" aria-hidden="true">
  <button class="overlay-close" id="overlay-close" aria-label="Close project details">&times;</button>
  <div class="overlay-content">
    <div class="overlay-image" id="overlay-image">
      <div class="overlay-image-noise"></div>
    </div>
    <div class="overlay-body">
      <span class="overlay-tag" id="overlay-tag"></span>
      <h2 class="overlay-title" id="overlay-title"></h2>
      <p class="overlay-description" id="overlay-description"></p>
      <div class="overlay-tech" id="overlay-tech"></div>
      <div class="overlay-links" id="overlay-links"></div>
    </div>
  </div>
</div>

<script define:vars={{ projectsJSON: JSON.stringify(projects) }}>
  window.__PROJECTS__ = JSON.parse(projectsJSON);
</script>

<style>
  .overlay-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(8, 8, 13, 0.75);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
  }

  .overlay-backdrop.active {
    pointer-events: auto;
  }

  .overlay {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.9);
    z-index: 201;
    background: var(--bg-elevated);
    border: 1px solid var(--border-subtle);
    border-radius: 24px;
    width: 90vw;
    max-width: 680px;
    max-height: 85vh;
    overflow-y: auto;
    opacity: 0;
    pointer-events: none;
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(255, 255, 255, 0.03);
  }

  .overlay.active {
    pointer-events: auto;
  }

  .overlay-close {
    position: sticky;
    top: 16px;
    float: right;
    margin: 16px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: var(--text-muted);
    font-size: 20px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s var(--ease-cinematic);
    z-index: 1;
  }

  .overlay-close:hover {
    background: rgba(255, 255, 255, 0.12);
    color: var(--text-primary);
  }

  .overlay-content {
    padding: 0;
  }

  .overlay-image {
    height: 220px;
    border-radius: 24px 24px 0 0;
    position: relative;
    overflow: hidden;
  }

  .overlay-image-noise {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    mix-blend-mode: overlay;
    pointer-events: none;
  }

  .overlay-body {
    padding: 32px 36px 36px;
  }

  .overlay-tag {
    display: inline-block;
    font-family: var(--font-body);
    color: var(--accent-start);
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 14px;
    font-weight: 400;
  }

  .overlay-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.3px;
  }

  .overlay-description {
    font-family: var(--font-body);
    color: var(--text-muted);
    font-size: 14px;
    line-height: 1.8;
    margin-bottom: 28px;
    font-weight: 300;
  }

  .overlay-tech {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 28px;
  }

  .overlay-tech :global(.tech-tag) {
    font-family: var(--font-body);
    background: rgba(124, 106, 239, 0.08);
    border: 1px solid rgba(124, 106, 239, 0.15);
    color: var(--accent-mid);
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.3px;
  }

  .overlay-links {
    display: flex;
    gap: 12px;
  }

  .overlay-links :global(.overlay-link) {
    font-family: var(--font-body);
    color: var(--text-muted);
    font-size: 13px;
    font-weight: 400;
    padding: 10px 22px;
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    transition: all 0.4s var(--ease-cinematic);
  }

  .overlay-links :global(.overlay-link:hover) {
    color: var(--text-primary);
    border-color: var(--border-glow);
    box-shadow: 0 0 16px rgba(124, 106, 239, 0.15);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .overlay {
      width: 100vw;
      max-width: 100vw;
      max-height: 100vh;
      height: 100vh;
      border-radius: 0;
      top: 0;
      left: 0;
      transform: translateY(100%);
    }

    .overlay-image {
      border-radius: 0;
    }
  }
</style>
