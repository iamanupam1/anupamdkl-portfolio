---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getSiteInfo } from '../../lib/content';

const site = await getSiteInfo();
const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title={`Blog — ${site.name}`}>
  <Nav solid />

  <main class="blog-listing" id="main-content">
    <div class="blog-listing-header">
      <a href="/" class="blog-listing-back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M13 8H3m0 0l4-4m-4 4l4 4" />
        </svg>
        Home
      </a>
      <h1 class="blog-listing-title">Blog</h1>
      <p class="blog-listing-subtitle">Thoughts on engineering, tooling, and the craft of building software.</p>
      <div class="blog-listing-bar"></div>
    </div>
    <div class="blog-listing-grid">
      {posts.length === 0 && (
        <p class="blog-empty">No posts yet. Check back soon.</p>
      )}
      {posts.map((post) => (
        <BlogCard
          slug={post.slug}
          title={post.data.title}
          summary={post.data.summary}
          date={post.data.date}
          tags={post.data.tags}
          gradient={post.data.gradient}
        />
      ))}
    </div>
  </main>
</Layout>

<style>
  .blog-listing {
    padding: 120px 48px 80px;
    max-width: 960px;
    margin: 0 auto;
  }

  .blog-listing-header {
    margin-bottom: 56px;
  }

  .blog-listing-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-dim);
    font-size: 13px;
    font-weight: 300;
    margin-bottom: 32px;
    transition: color 0.3s;
  }

  .blog-listing-back:hover {
    color: var(--accent);
  }

  .blog-listing-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
  }

  .blog-listing-subtitle {
    color: var(--text-dim);
    font-size: 16px;
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 480px;
  }

  .blog-listing-bar {
    width: 48px;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  .blog-listing-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  /* Entrance animation */
  .blog-listing-grid :global(.blog-card) {
    opacity: 0;
    animation: fadeUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .blog-listing-grid :global(.blog-card:nth-child(1)) { animation-delay: 0.05s; }
  .blog-listing-grid :global(.blog-card:nth-child(2)) { animation-delay: 0.12s; }
  .blog-listing-grid :global(.blog-card:nth-child(3)) { animation-delay: 0.19s; }
  .blog-listing-grid :global(.blog-card:nth-child(4)) { animation-delay: 0.26s; }
  .blog-listing-grid :global(.blog-card:nth-child(5)) { animation-delay: 0.33s; }
  .blog-listing-grid :global(.blog-card:nth-child(6)) { animation-delay: 0.40s; }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .blog-listing {
      padding: 100px 24px 60px;
    }

    .blog-listing-grid {
      grid-template-columns: 1fr;
    }
  }

  .blog-empty {
    color: var(--text-dim);
    font-size: 16px;
    text-align: center;
    padding: 48px 0;
    grid-column: 1 / -1;
  }
</style>
