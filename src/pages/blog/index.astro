---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Blog — Anupam">
  <nav class="blog-nav">
    <a href="/" class="blog-nav-logo">ANUPAM</a>
    <div class="blog-nav-links">
      <a href="/#work" class="blog-nav-link">Work</a>
      <a href="/#blog" class="blog-nav-link">Blog</a>
      <a href="/#about" class="blog-nav-link">About</a>
      <a href="/#contact" class="blog-nav-link">Contact</a>
    </div>
  </nav>

  <main class="blog-listing">
    <div class="blog-listing-header">
      <a href="/" class="blog-listing-back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 8H3m0 0l4-4m-4 4l4 4" />
        </svg>
        Home
      </a>
      <span class="section-label">Blog</span>
      <h1 class="section-title">All posts</h1>
    </div>
    <div class="blog-listing-grid">
      {posts.map((post) => (
        <BlogCard
          slug={post.slug}
          title={post.data.title}
          summary={post.data.summary}
          date={post.data.date}
          tags={post.data.tags}
          gradient={post.data.gradient}
        />
      ))}
    </div>
  </main>
</Layout>

<style>
  .blog-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 48px;
    background: rgba(10, 10, 15, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .blog-nav-logo {
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 2px;
    color: #e2e8f0;
  }

  .blog-nav-links {
    display: flex;
    gap: 32px;
  }

  .blog-nav-link {
    color: #94a3b8;
    font-size: 13px;
    letter-spacing: 0.5px;
    transition: color 0.3s;
  }

  .blog-nav-link:hover {
    color: #e2e8f0;
  }

  .blog-listing {
    padding: 120px 48px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-listing-header {
    margin-bottom: 48px;
  }

  .blog-listing-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #94a3b8;
    font-size: 13px;
    margin-bottom: 24px;
    transition: color 0.3s;
  }

  .blog-listing-back:hover {
    color: #e2e8f0;
  }

  .section-label {
    display: block;
    color: #6366f1;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: 36px;
    font-weight: 300;
    margin-bottom: 48px;
  }

  .blog-listing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 24px;
  }

  /* Entrance animation for listing page cards */
  .blog-listing-grid :global(.blog-card) {
    opacity: 0;
    animation: fadeUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .blog-listing-grid :global(.blog-card:nth-child(1)) { animation-delay: 0.1s; }
  .blog-listing-grid :global(.blog-card:nth-child(2)) { animation-delay: 0.2s; }
  .blog-listing-grid :global(.blog-card:nth-child(3)) { animation-delay: 0.3s; }
  .blog-listing-grid :global(.blog-card:nth-child(4)) { animation-delay: 0.4s; }
  .blog-listing-grid :global(.blog-card:nth-child(5)) { animation-delay: 0.5s; }
  .blog-listing-grid :global(.blog-card:nth-child(6)) { animation-delay: 0.6s; }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .blog-nav {
      padding: 20px 24px;
    }

    .blog-nav-links {
      display: none;
    }

    .blog-listing {
      padding: 100px 24px;
    }

    .blog-listing-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
