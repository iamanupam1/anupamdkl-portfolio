---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="Page Not Found — Anupam">
  <Nav solid />

  <main class="not-found" id="main-content">
    <span class="not-found-code">404</span>
    <h1 class="not-found-title">Page not found</h1>
    <p class="not-found-text">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="not-found-link">Back to home</a>
  </main>
</Layout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 48px;
    text-align: center;
  }

  .not-found-code {
    font-family: var(--font-display);
    font-size: clamp(80px, 15vw, 160px);
    font-weight: 800;
    color: var(--accent-tint);
    line-height: 1;
    margin-bottom: 16px;
  }

  .not-found-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 36px);
    font-weight: 700;
    margin-bottom: 12px;
  }

  .not-found-text {
    color: var(--text-dim);
    font-size: 16px;
    margin-bottom: 32px;
    max-width: 400px;
  }

  .not-found-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border: 1px solid var(--border-accent);
    border-radius: 8px;
    color: var(--accent);
    font-size: 14px;
    transition: all 0.3s var(--ease-cinematic);
  }

  .not-found-link:hover {
    border-color: var(--accent);
    color: var(--text-primary);
    box-shadow: 0 0 20px var(--accent-glow);
  }

  @media (max-width: 768px) {
    .not-found {
      padding: 24px;
    }

    .not-found-text {
      max-width: 300px;
    }
  }
</style>
