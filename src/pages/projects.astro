---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import { projects } from '../data/projects';
---

<Layout title="Projects — Anupam">
  <Nav solid />

  <main class="projects-listing" id="main-content">
    <div class="projects-listing-header">
      <a href="/" class="projects-listing-back">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M13 8H3m0 0l4-4m-4 4l4 4" />
        </svg>
        Home
      </a>
      <h1 class="projects-listing-title">Projects</h1>
      <p class="projects-listing-subtitle">A selection of things I've built — from developer tools to real-time platforms.</p>
      <div class="projects-listing-bar"></div>
    </div>

    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card">
          <div class="project-card-header">
            <span class="project-card-tag">{project.tag}</span>
            <h2 class="project-card-title">{project.title}</h2>
            <p class="project-card-desc">{project.description}</p>
          </div>
          <div class="project-card-footer">
            <div class="project-card-tech">
              {project.techStack.map((tech) => (
                <span class="project-card-pill">{tech}</span>
              ))}
            </div>
            <div class="project-card-links">
              {project.liveUrl && (
                <a href={project.liveUrl} class="project-card-link" target="_blank" rel="noopener noreferrer">
                  Live Demo
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 3h8v8m0-8L5 11" />
                  </svg>
                </a>
              )}
              {project.githubUrl && (
                <a href={project.githubUrl} class="project-card-link" target="_blank" rel="noopener noreferrer">
                  GitHub
                  <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 3h8v8m0-8L5 11" />
                  </svg>
                </a>
              )}
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>

<style>
  .projects-listing {
    padding: 120px 48px 80px;
    max-width: 960px;
    margin: 0 auto;
  }

  .projects-listing-header {
    margin-bottom: 56px;
  }

  .projects-listing-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--text-dim);
    font-size: 13px;
    font-weight: 300;
    margin-bottom: 32px;
    transition: color 0.3s;
  }

  .projects-listing-back:hover {
    color: var(--accent);
  }

  .projects-listing-title {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 44px);
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: 12px;
  }

  .projects-listing-subtitle {
    color: var(--text-dim);
    font-size: 16px;
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 24px;
    max-width: 480px;
  }

  .projects-listing-bar {
    width: 48px;
    height: 2px;
    background: var(--accent);
    border-radius: 1px;
  }

  /* --- Grid --- */
  .projects-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* --- Card --- */
  .project-card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 36px;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
    opacity: 0;
    animation: fadeUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }

  .project-card:nth-child(1) { animation-delay: 0.05s; }
  .project-card:nth-child(2) { animation-delay: 0.12s; }
  .project-card:nth-child(3) { animation-delay: 0.19s; }
  .project-card:nth-child(4) { animation-delay: 0.26s; }
  .project-card:nth-child(5) { animation-delay: 0.33s; }

  .project-card:hover {
    border-color: var(--border-accent);
    transform: translateY(-3px);
    box-shadow: 0 12px 32px var(--card-shadow);
  }

  .project-card-header {
    margin-bottom: 24px;
  }

  .project-card-tag {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-tint);
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  .project-card-title {
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.2px;
  }

  .project-card-desc {
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.7;
    font-weight: 300;
  }

  .project-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .project-card-tech {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .project-card-pill {
    font-size: 11px;
    color: var(--text-dim);
    border: 1px solid var(--border-subtle);
    padding: 4px 12px;
    border-radius: 20px;
    letter-spacing: 0.3px;
  }

  .project-card-links {
    display: flex;
    gap: 16px;
  }

  .project-card-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--text-dim);
    font-size: 13px;
    transition: color 0.2s;
  }

  .project-card-link:hover {
    color: var(--accent);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .projects-listing {
      padding: 100px 24px 60px;
    }

    .project-card {
      padding: 28px;
    }

    .project-card-title {
      font-size: 20px;
    }

    .project-card-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
